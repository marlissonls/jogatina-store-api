<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Imports Spring color defaults -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Defines the console pattern with the configured MDC variables -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%X{correlationId:-CorrID}]){cyan} %clr([%X{user:-User}]){faint} %clr([%X{method:-Method}]){yellow} %clr([%X{path:-Path}]){blue} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <!-- Defines the Application log level -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
